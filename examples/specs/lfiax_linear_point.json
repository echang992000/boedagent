{
  "problem_summary": "Scalar linear-Gaussian BOED with the LFIAX backend using the differentiable point-design path.",
  "backend": "lfiax",
  "simulator_ref": "boed_agent.demo.lfiax_linear:simulator",
  "prior_sampler_ref": "boed_agent.demo.lfiax_linear:prior",
  "differentiable": true,
  "design_variables": [
    {
      "name": "xi",
      "lower": -2.0,
      "upper": 2.0,
      "initial": 0.25
    }
  ],
  "observation_labels": ["y"],
  "target_latent_labels": ["theta"],
  "compute_budget": {
    "num_outer_samples": 16,
    "num_inner_samples": 4,
    "num_optimization_steps": 2000,
    "design_learning_rate": 0.02,
    "flow_learning_rate": 0.001
  },
  "objective": {
    "name": "expected_information_gain",
    "estimator": "lf_pce_eig_scan",
    "estimator_kwargs": {
      "lam": 0.5
    }
  },
  "backend_options": {
    "design_mode": "point"
  },
  "surrogate": {
    "checkpoint_filename": "linear_point_likelihood.pkl"
  },
  "recreate_trajectory": true,
  "artifacts": {
    "output_dir": "artifacts",
    "save_trajectory_plot": true
  }
}
